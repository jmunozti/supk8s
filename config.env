# supK8s Configuration
# Edit these values before running make deploy

# ArgoCD repo URL — REQUIRED: change to your own fork.
# The `make simulate-failure` flow works via GitOps: it commits a broken image
# to the repo and ArgoCD pulls it. So ArgoCD must point at the same repo your
# local clone pushes to. If you don't have push access to the URL below, fork
# it on GitHub and set ARGOCD_REPO_URL to your fork.
ARGOCD_REPO_URL=https://github.com/jmunozti/supk8s.git
ARGOCD_BRANCH=develop

# Agent settings
ERROR_THRESHOLD=0.3
CHECK_INTERVAL=15
ROLLBACK_IMAGE=demo-app:v1

# OpenRouter LLM (optional — leave empty to disable AI root-cause analysis)
# Get a free key at https://openrouter.ai/keys
# Free models: https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_API_KEY is loaded from .env (gitignored) — do NOT put it here

# ArgoCD credentials
ARGOCD_ADMIN_PASSWORD=supk8s-admin
